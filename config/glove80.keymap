            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms = <0>;
            bindings = <&macro_tap &kp LC(LS(U)) &kp N1 &kp F &kp N6 &kp N3 &kp N3 &kp ENTER>;
        };



    };

    combos {
        compatible = "zmk,combos";

        combo_undo {
            timeout-ms = <30>;
            key-positions = <67 68>;
            require-prior-idle-ms = <300>;
            layers = <ALL_LAYERS>;
            bindings = <&kp LC(Z)>;
        };


        combo_redo {
            timeout-ms = <30>;
            key-positions = <75 76>;
            require-prior-idle-ms = <300>;
            layers = <ALL_LAYERS>;
            bindings = <&kp LC(LS(Z))>;
        };

        // combo_escape {
        //     timeout-ms = <30>;
        //     key-positions = <67 68>;
        //     require-prior-idle-ms = <400>;
        //     layers = <ALL_LAYERS>;
        //     bindings = <&kp ESC>;
        // };


        combo_null {
            timeout-ms = <30>;
            key-positions = <73 74>;
            require-prior-idle-ms = <200>;
            layers = <ALL_LAYERS>;
            bindings = <&kp 0>;
        };

    };

    conditional_layers {
        compatible = "zmk,conditional-layers";


        activate_coding_nums_syms_layer {
            if-layers = <CODING NUMS_SYMS>;
            then-layer = <CODING_NUMS_SYMS>;
        };

        activate_no_padding_coding_layer {
            if-layers = <NO_PAD CODING>;
            then-layer = <NO_PAD_CODING>;
        };

        activate_no_padding_coding_num_syms_layer {
            if-layers = <NO_PAD CODING NUMS_SYMS>;
            then-layer = <NO_PAD_CODING_NUMS_SYMS>;
        };

        activate_javascript_bigram_layer {
            if-layers = <CODING TS BIGRAM>;
            then-layer = <TS_BIGRAM>;
        };

        activate_no_padding_bigram_layer {
            if-layers = <NO_PAD CODING BIGRAM>;
            then-layer = <NO_PAD_BIGRAM>;
        };

        activate_javascript_double_layer {
            if-layers = <TS DBL>;
            then-layer = <TS_DBL>;
        };

        activate_no_padding_double_layer {
            if-layers = <NO_PAD CODING DBL>;
            then-layer = <NO_PAD_DBL>;
        };

        activate_javascript_keywords_layer {
            if-layers = <CODING TS KEYW>;
            then-layer = <TS_KEYW>;
        };

        activate_c_keywords_layer {
            if-layers = <CODING C_LANG KEYW>;
            then-layer = <C_KEYW>;
        };

        activate_python_keywords_layer {
            if-layers = <CODING TS C_LANG KEYW>;
            then-layer = <PYTHON_KEYW>;
        };
    };


